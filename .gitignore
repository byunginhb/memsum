# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts
.expo-shared/

# Native: CNG 생성 디렉토리는 expo prebuild로 재생성 (modules/의 네이티브 소스가 SSOT)
# 참고: projectmd 문서는 ios/android 커밋을 권장하나, 모던 Expo CNG 관행에 따라 제외한다.
# `expo run:ios` / `expo run:android` 실행 시 자동 prebuild로 재생성됨.
# (커밋을 원하면 아래 /ios/ /android/ 두 줄을 제거하고 빌드 산출물만 따로 무시할 것.)
/ios/
/android/

# 로컬 네이티브 모듈 빌드 산출물
modules/*/android/build/
modules/*/android/.gradle/
modules/*/android/.cxx/
modules/*/ios/build/
*.keystore
!debug.keystore

# 환경 변수 (시크릿)
.env
.env*.local

# OAuth 자격증명 파일 (시크릿 — 절대 커밋 금지)
# Google Cloud Console에서 내려받은 client_secret / plist 원본.
# 코드는 EXPO_PUBLIC_* 환경변수의 client ID만 사용한다.
docs/android_json/
docs/ios_plist/
**/client_secret_*.json
**/client_*.apps.googleusercontent.com.plist
GoogleService-Info.plist
google-services.json

# 로그
*.log
npm-debug.*
yarn-error.*

# macOS
.DS_Store

# Metro
.metro-health-check*

# 테스트/커버리지
coverage/

# 하네스 런타임 상태 (커밋 제외)
.claude/
.omc/
