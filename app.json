{
  "expo": {
    "name": "Memsum",
    "slug": "memsum",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "memsum",
      "com.googleusercontent.apps.649138266676-kkj5lepd53o1fu8ha04tppj6qd9604nk",
      "com.googleusercontent.apps.649138266676-j8bl0afld4bfps2cldigvltfd677elvi"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.memsum",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "스크린샷 자동 감지를 위해 사진 접근이 필요해요. Memsum은 스크린샷만 인식하고 다른 사진은 보지 않습니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.memsum",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#7C6FE8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#7C6FE8",
          "dark": {
            "backgroundColor": "#7C6FE8"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "69fe853c-3143-4c40-95b1-70896b727b4f"
      }
    },
    "owner": "bensong"
  }
}
