{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "[[APPLE_ID_이메일]]",
        "ascAppId": "[[APP_STORE_CONNECT_APP_ID]]",
        "appleTeamId": "[[APPLE_TEAM_ID]]"
      },
      "android": {
        "serviceAccountKeyPath": "[[GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_경로]]",
        "track": "internal"
      }
    }
  }
}
