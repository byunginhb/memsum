# Supabase — supabase.com에서 memsum 프로젝트 생성 후 직접 입력
# (Settings → API → Project URL / anon public key)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# DB 마이그레이션 전용 (서버 시크릿 — EXPO_PUBLIC_ 아님, 앱 번들에 포함 안 됨).
# Settings → Database → Connection string → URI (비밀번호 포함). Session pooler 권장.
# `pnpm db:migrate` 가 이 값으로 supabase/migrations/*.sql 을 적용한다.
SUPABASE_DB_URL=

# Google 캘린더 OAuth — 네이티브 Authorization Code + PKCE (public client, secret 불필요).
# Google Cloud Console → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID(iOS/Android) 발급.
# Web 클라이언트 ID는 네이티브 PKCE 플로우에 불필요.
# ⚠️ 발급된 클라이언트 ID의 reversed scheme(com.googleusercontent.apps.<prefix>)을
#    app.json 의 "scheme" 배열에 등록해야 OAuth 리다이렉트가 앱으로 복귀한다.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# WebView (다음 단계)
# EXPO_PUBLIC_WEBVIEW_URL=https://web.memsum.app

# 관측 (다음 단계)
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_POSTHOG_KEY=
